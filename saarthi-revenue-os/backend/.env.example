# ── Database ──────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/saarthi

# ── Redis & Celery ────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── Auth (Mandatory) ──────────────────────────────
# Must be a secure, random string in production
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Provider Token AES Encryption 
# Must be exactly 32 bytes for AES-256-GCM
ENCRYPTION_KEY=

# ── App ───────────────────────────────────────────
APP_NAME=Saarthi
FRONTEND_URL=http://localhost:3000

# ── Email Providers ───────────────────────────────
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SENDGRID_API_KEY=
RESEND_API_KEY=

# ── AI Providers ──────────────────────────────────
OPENAI_API_KEY=

# ── OAuth Providers (Google & Entra ID) ───────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ── Stripe ────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── External AI & classification ──────────────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# ── Lead Generation & Calendar Providers ─────────
APIFY_TOKEN=
SERPAPI_KEY=
CALENDLY_API_KEY=
